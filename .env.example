# ============================================================
# AI Brand & Marketing OS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# On Replit: all variables below are set automatically.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL Database
# On Replit: set automatically by the PostgreSQL integration.
# Locally: create a Postgres DB and paste the connection URL.
# ----------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/brandos

# ----------------------------------------------------------
# OpenAI API
# On Replit: set automatically by the OpenAI AI Integration.
# Locally: use your own OpenAI API key from platform.openai.com
#          and set the base URL to the standard OpenAI endpoint.
# ----------------------------------------------------------
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-api-key-here

# ----------------------------------------------------------
# Server Port (API)
# On Replit: set automatically by the artifact system.
# Locally: set to any free port.
# ----------------------------------------------------------
PORT=8080

# ----------------------------------------------------------
# Frontend Base Path (Vite)
# On Replit: set automatically by the artifact system.
# Locally: use "/" so the app is served at the root.
# ----------------------------------------------------------
BASE_PATH=/
